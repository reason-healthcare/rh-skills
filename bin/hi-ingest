#!/usr/bin/env bash
# bin/hi-ingest — Register and track raw L1 source artifacts (repo-wide)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=common.sh
source "$SCRIPT_DIR/common.sh"

usage() {
  cat <<EOF
Usage: hi ingest <subcommand> [options]

Subcommands:
  plan        Generate an ingest plan listing sources to register
  implement   Copy sources into l1/ and record checksums in tracking.yaml
  verify      Re-checksum all registered L1 sources and report changes

Options for 'plan':
  --force      Overwrite existing ingest-plan.md

Options for 'implement':
  --force      Re-ingest already-registered sources

Options:
  -h, --help   Print usage

Exit codes:
  0  Success
  1  Verify found changed or missing sources
  2  Usage error / missing prerequisite

Examples:
  hi ingest plan
  hi ingest implement
  hi ingest verify
EOF
}

# ── plan ──────────────────────────────────────────────────────────────────────

cmd_plan() {
  local force=0

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --force)   force=1; shift ;;
      -h|--help) usage; exit 0 ;;
      *) hi_log_error "Unknown option: $1"; usage; exit 2 ;;
    esac
  done

  local repo_root
  repo_root="$(hi_repo_root)"
  local plan_file="$repo_root/plans/ingest-plan.md"

  if [[ -f "$plan_file" && "$force" -eq 0 ]]; then
    hi_log_warn "ingest-plan.md already exists. Use --force to overwrite."
    exit 0
  fi

  local sources_yaml='- name: source-1
  path_or_url: "# TODO: local file path or URL to download"
  type: document'

  mkdir -p "$repo_root/plans"
  cat > "$plan_file" <<MARKDOWN
---
sources:
$(printf '%s\n' "$sources_yaml" | sed 's/^/  /' | sed 's/^  -/- /')
---

# Ingest Plan

Review and update the \`sources\` list above before running \`hi ingest implement\`.

## Fields

- **name**: Identifier used for the \`l1/<name>.md\` file (kebab-case)
- **path_or_url**: Absolute local path to the source file, or a URL to download
- **type**: One of \`pdf\`, \`word\`, \`excel\`, \`markdown\`, \`html\`, \`document\`

## Next Step

After editing this file:

\`\`\`
hi ingest implement
\`\`\`
MARKDOWN

  hi_log_info "Created: $plan_file"
}

# ── implement ─────────────────────────────────────────────────────────────────

cmd_implement() {
  local force=0

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --force)   force=1; shift ;;
      -h|--help) usage; exit 0 ;;
      *) hi_log_error "Unknown option: $1"; usage; exit 2 ;;
    esac
  done

  local repo_root
  repo_root="$(hi_repo_root)"
  local plan_file="$repo_root/plans/ingest-plan.md"

  if [[ ! -f "$plan_file" ]]; then
    hi_log_error "No ingest-plan.md found. Run 'hi ingest plan' first."
    exit 2
  fi

  local tracking
  tracking="$(hi_tracking_file)"
  local l1_dir
  l1_dir="$(hi_l1_root)"
  mkdir -p "$l1_dir"

  # Read sources[] from plan front matter
  local front
  front=$(hi_markdown_get_frontmatter_block "$plan_file") || {
    hi_log_error "Could not read front matter from $plan_file"
    exit 2
  }

  local source_count
  source_count=$(printf '%s\n' "$front" | yq eval '.sources | length' - 2>/dev/null || echo 0)

  if [[ "$source_count" -eq 0 ]]; then
    hi_log_warn "No sources defined in ingest-plan.md"
    exit 0
  fi

  local i=0
  while [[ "$i" -lt "$source_count" ]]; do
    local src_name src_path src_type
    src_name=$(printf '%s\n' "$front" | yq eval ".sources[$i].name" - 2>/dev/null || echo "")
    src_path=$(printf '%s\n' "$front" | yq eval ".sources[$i].path_or_url" - 2>/dev/null || echo "")
    src_type=$(printf '%s\n' "$front" | yq eval ".sources[$i].type" - 2>/dev/null || echo "document")

    if [[ -z "$src_name" || "$src_name" == "null" ]]; then
      hi_log_warn "Skipping source[$i]: missing name"
      i=$((i + 1))
      continue
    fi

    # Skip TODO placeholders
    if printf '%s' "$src_path" | grep -q "^#"; then
      hi_log_warn "Skipping $src_name: path_or_url is a placeholder (edit ingest-plan.md)"
      i=$((i + 1))
      continue
    fi

    local dest_file="$l1_dir/$src_name.md"

    if [[ -f "$dest_file" && "$force" -eq 0 ]]; then
      hi_log_warn "$src_name already registered. Use --force to re-ingest."
      i=$((i + 1))
      continue
    fi

    # Copy or handle the source
    if [[ -f "$src_path" ]]; then
      cp "$src_path" "$dest_file"
    else
      hi_log_error "Source file not found: $src_path (for $src_name)"
      i=$((i + 1))
      continue
    fi

    # Compute checksum
    local checksum
    checksum=$(hi_sha256 "$dest_file")

    # Optional text extraction
    local text_extracted=false
    local txt_file="$l1_dir/$src_name.txt"

    if [[ "$src_type" == "pdf" ]]; then
      if command -v pdftotext > /dev/null 2>&1; then
        pdftotext "$dest_file" "$txt_file" 2>/dev/null && text_extracted=true
      else
        hi_log_warn "text extraction skipped: pdftotext not found (install: brew install poppler)"
      fi
    elif [[ "$src_type" == "word" || "$src_type" == "excel" ]]; then
      if command -v pandoc > /dev/null 2>&1; then
        pandoc -o "$txt_file" "$dest_file" 2>/dev/null && text_extracted=true
      else
        hi_log_warn "text extraction skipped: pandoc not found (install: brew install pandoc)"
      fi
    fi

    # Append source entry to root .l1 list in tracking.yaml
    local ingested_at
    ingested_at="$(hi_timestamp)"

    yq eval -i ".l1 += [{
      \"name\": \"$src_name\",
      \"file\": \"l1/$src_name.md\",
      \"type\": \"$src_type\",
      \"checksum\": \"$checksum\",
      \"ingested_at\": \"$ingested_at\",
      \"text_extracted\": $text_extracted
    }]" "$tracking" 2>/dev/null

    # Append l1_added event to root .events list
    hi_tracking_append_root_event "$tracking" "l1_added" "Ingested source: $src_name"

    hi_log_info "Registered: $src_name (checksum: ${checksum:0:12}...)"
    i=$((i + 1))
  done
}

# ── verify ────────────────────────────────────────────────────────────────────

cmd_verify() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help) usage; exit 0 ;;
      *) hi_log_error "Unknown option: $1"; usage; exit 2 ;;
    esac
  done

  local tracking
  tracking="$(hi_tracking_file)"

  local source_count
  source_count=$(yq eval ".l1 | length" "$tracking" 2>/dev/null || echo 0)

  if [[ "$source_count" -eq 0 ]]; then
    printf 'No L1 sources registered\n'
    exit 0
  fi

  local l1_root
  l1_root="$(hi_l1_root)"
  local any_changed=0
  local i=0
  while [[ "$i" -lt "$source_count" ]]; do
    local src_name src_file stored_checksum
    src_name=$(yq eval ".l1[$i].name" "$tracking" 2>/dev/null || echo "")
    src_file=$(yq eval ".l1[$i].file" "$tracking" 2>/dev/null || echo "")
    stored_checksum=$(yq eval ".l1[$i].checksum" "$tracking" 2>/dev/null || echo "")

    local full_path="$l1_root/$src_name.md"

    if [[ ! -f "$full_path" ]]; then
      printf '✗ %-30s MISSING\n' "$src_name"
      any_changed=1
      i=$((i + 1))
      continue
    fi

    local current_checksum
    current_checksum=$(hi_sha256 "$full_path")

    if [[ "$current_checksum" == "$stored_checksum" ]]; then
      printf '✓ %-30s OK\n' "$src_name"
    else
      printf '✗ %-30s CHANGED\n  was: %s\n  now: %s\n' \
        "$src_name" "$stored_checksum" "$current_checksum"
      any_changed=1
    fi

    i=$((i + 1))
  done

  if [[ "$any_changed" -eq 1 ]]; then
    printf '\nRun `hi ingest implement --force` to re-register changed sources.\n'
    exit 1
  fi
}

# ── dispatcher ───────────────────────────────────────────────────────────────

main() {
  if [[ $# -eq 0 || "$1" == "--help" || "$1" == "-h" ]]; then
    usage; exit 0
  fi

  local subcommand="$1"; shift

  case "$subcommand" in
    plan)      cmd_plan      "$@" ;;
    implement) cmd_implement "$@" ;;
    verify)    cmd_verify    "$@" ;;
    *) hi_log_error "Unknown subcommand: $subcommand"; usage; exit 2 ;;
  esac
}

main "$@"


set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=common.sh
source "$SCRIPT_DIR/common.sh"

usage() {
  cat <<EOF
Usage: hi ingest <subcommand> <topic> [options]

Subcommands:
  plan        Generate an ingest plan listing sources to register
  implement   Copy sources into topics/<topic>/l1/ and record checksums
  verify      Re-checksum all registered sources and report changes

Arguments:
  topic        Topic name (must already exist)

Options for 'plan':
  --force      Overwrite existing ingest-plan.md

Options for 'implement':
  --force      Re-ingest already-registered sources

Options:
  -h, --help   Print usage

Exit codes:
  0  Success
  1  Verify found changed or missing sources
  2  Usage error / missing prerequisite

Examples:
  hi ingest plan diabetes-screening
  hi ingest implement diabetes-screening
  hi ingest verify diabetes-screening
EOF
}

# ── plan ──────────────────────────────────────────────────────────────────────

cmd_plan() {
  local topic_name="$1"; shift
  local force=0

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --force)   force=1; shift ;;
      -h|--help) usage; exit 0 ;;
      *) hi_log_error "Unknown option: $1"; usage; exit 2 ;;
    esac
  done

  hi_require_topic "$topic_name"
  local topic_dir
  topic_dir="$(hi_topic_dir "$topic_name")"
  local plan_file="$topic_dir/plans/ingest-plan.md"

  if [[ -f "$plan_file" && "$force" -eq 0 ]]; then
    hi_log_warn "ingest-plan.md already exists. Use --force to overwrite."
    exit 0
  fi

  # Read source hints from discovery-plan.md if present
  local discovery_plan="$topic_dir/plans/discovery-plan.md"
  local source_hints=""
  if [[ -f "$discovery_plan" ]]; then
    source_hints=$(hi_markdown_get_frontmatter_block "$discovery_plan" 2>/dev/null || true)
  fi

  # Build initial sources list from discovery plan or scaffold a template
  local sources_yaml
  if [[ -n "$source_hints" ]]; then
    # Extract names from discovery-plan sources[] to pre-populate
    sources_yaml=$(printf '%s\n' "$source_hints" | yq eval '.sources // []' - 2>/dev/null || echo "[]")
    # Remap to ingest-plan format: keep name, add path_or_url/type placeholders if missing
    sources_yaml=$(printf '%s\n' "$sources_yaml" | \
      yq eval '[.[] | {"name": .name, "path_or_url": (.path_or_url // "# TODO: local path or URL"), "type": (.type // "document")}]' - 2>/dev/null || echo "[]")
  else
    sources_yaml='- name: source-1
  path_or_url: "# TODO: local file path or URL to download"
  type: document'
  fi

  mkdir -p "$topic_dir/plans"
  cat > "$plan_file" <<MARKDOWN
---
sources:
$(printf '%s\n' "$sources_yaml" | sed 's/^/  /' | sed 's/^  -/- /')
---

# Ingest Plan: $topic_name

Review and update the \`sources\` list above before running \`hi ingest implement\`.

## Fields

- **name**: Identifier used for the \`l1/<name>.md\` file (kebab-case)
- **path_or_url**: Absolute local path to the source file, or a URL to download
- **type**: One of \`pdf\`, \`word\`, \`excel\`, \`markdown\`, \`html\`, \`document\`

## Next Step

After editing this file:

\`\`\`
hi ingest implement $topic_name
\`\`\`
MARKDOWN

  hi_log_info "Created: $plan_file"
}

# ── implement ─────────────────────────────────────────────────────────────────

cmd_implement() {
  local topic_name="$1"; shift
  local force=0

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --force)   force=1; shift ;;
      -h|--help) usage; exit 0 ;;
      *) hi_log_error "Unknown option: $1"; usage; exit 2 ;;
    esac
  done

  hi_require_topic "$topic_name"
  local topic_dir
  topic_dir="$(hi_topic_dir "$topic_name")"
  local plan_file="$topic_dir/plans/ingest-plan.md"

  if [[ ! -f "$plan_file" ]]; then
    hi_log_error "No ingest-plan.md found. Run 'hi ingest plan $topic_name' first."
    exit 2
  fi

  local tracking
  tracking="$(hi_tracking_file)"
  local l1_dir="$topic_dir/l1"
  mkdir -p "$l1_dir"

  # Read sources[] from plan front matter
  local front
  front=$(hi_markdown_get_frontmatter_block "$plan_file") || {
    hi_log_error "Could not read front matter from $plan_file"
    exit 2
  }

  local source_count
  source_count=$(printf '%s\n' "$front" | yq eval '.sources | length' - 2>/dev/null || echo 0)

  if [[ "$source_count" -eq 0 ]]; then
    hi_log_warn "No sources defined in ingest-plan.md"
    exit 0
  fi

  local i=0
  while [[ "$i" -lt "$source_count" ]]; do
    local src_name src_path src_type
    src_name=$(printf '%s\n' "$front" | yq eval ".sources[$i].name" - 2>/dev/null || echo "")
    src_path=$(printf '%s\n' "$front" | yq eval ".sources[$i].path_or_url" - 2>/dev/null || echo "")
    src_type=$(printf '%s\n' "$front" | yq eval ".sources[$i].type" - 2>/dev/null || echo "document")

    if [[ -z "$src_name" || "$src_name" == "null" ]]; then
      hi_log_warn "Skipping source[$i]: missing name"
      i=$((i + 1))
      continue
    fi

    # Skip TODO placeholders
    if printf '%s' "$src_path" | grep -q "^#"; then
      hi_log_warn "Skipping $src_name: path_or_url is a placeholder (edit ingest-plan.md)"
      i=$((i + 1))
      continue
    fi

    local dest_file="$l1_dir/$src_name.md"

    if [[ -f "$dest_file" && "$force" -eq 0 ]]; then
      hi_log_warn "$src_name already registered. Use --force to re-ingest."
      i=$((i + 1))
      continue
    fi

    # Copy or handle the source
    if [[ -f "$src_path" ]]; then
      cp "$src_path" "$dest_file"
    else
      hi_log_error "Source file not found: $src_path (for $src_name)"
      i=$((i + 1))
      continue
    fi

    # Compute checksum
    local checksum
    checksum=$(hi_sha256 "$dest_file")

    # Optional text extraction
    local text_extracted=false
    local txt_file="$l1_dir/$src_name.txt"

    if [[ "$src_type" == "pdf" ]]; then
      if command -v pdftotext > /dev/null 2>&1; then
        pdftotext "$dest_file" "$txt_file" 2>/dev/null && text_extracted=true
      else
        hi_log_warn "text extraction skipped: pdftotext not found (install: brew install poppler)"
      fi
    elif [[ "$src_type" == "word" || "$src_type" == "excel" ]]; then
      if command -v pandoc > /dev/null 2>&1; then
        pandoc -o "$txt_file" "$dest_file" 2>/dev/null && text_extracted=true
      else
        hi_log_warn "text extraction skipped: pandoc not found (install: brew install pandoc)"
      fi
    fi

    # Append source entry to tracking.yaml l1 sources
    local ingested_at
    ingested_at="$(hi_timestamp)"

    yq eval -i "(.topics[] | select(.name == \"$topic_name\") | .artifacts.l1) += [{
      \"name\": \"$src_name\",
      \"file\": \"topics/$topic_name/l1/$src_name.md\",
      \"type\": \"$src_type\",
      \"checksum\": \"$checksum\",
      \"ingested_at\": \"$ingested_at\",
      \"text_extracted\": $text_extracted
    }]" "$tracking" 2>/dev/null

    hi_tracking_append_event "$tracking" "$topic_name" "l1_added" "Ingested source: $src_name"

    hi_log_info "Registered: $src_name (checksum: ${checksum:0:12}...)"
    i=$((i + 1))
  done
}

# ── verify ────────────────────────────────────────────────────────────────────

cmd_verify() {
  local topic_name="$1"; shift

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help) usage; exit 0 ;;
      *) hi_log_error "Unknown option: $1"; usage; exit 2 ;;
    esac
  done

  hi_require_topic "$topic_name"
  local topic_dir
  topic_dir="$(hi_topic_dir "$topic_name")"
  local tracking
  tracking="$(hi_tracking_file)"

  local source_count
  source_count=$(yq eval ".topics[] | select(.name == \"$topic_name\") | .artifacts.l1 | length" "$tracking" 2>/dev/null || echo 0)

  if [[ "$source_count" -eq 0 ]]; then
    printf 'No L1 sources registered for %s\n' "$topic_name"
    exit 0
  fi

  local any_changed=0
  local i=0
  while [[ "$i" -lt "$source_count" ]]; do
    local src_name src_file stored_checksum
    src_name=$(yq eval ".topics[] | select(.name == \"$topic_name\") | .artifacts.l1[$i].name" "$tracking" 2>/dev/null || echo "")
    src_file=$(yq eval ".topics[] | select(.name == \"$topic_name\") | .artifacts.l1[$i].file" "$tracking" 2>/dev/null || echo "")
    stored_checksum=$(yq eval ".topics[] | select(.name == \"$topic_name\") | .artifacts.l1[$i].checksum" "$tracking" 2>/dev/null || echo "")

    local full_path
    full_path="$(hi_repo_root)/$src_file"

    if [[ ! -f "$full_path" ]]; then
      printf '✗ %-30s MISSING\n' "$src_name"
      any_changed=1
      i=$((i + 1))
      continue
    fi

    local current_checksum
    current_checksum=$(hi_sha256 "$full_path")

    if [[ "$current_checksum" == "$stored_checksum" ]]; then
      printf '✓ %-30s OK\n' "$src_name"
    else
      printf '✗ %-30s CHANGED\n  was: %s\n  now: %s\n' \
        "$src_name" "$stored_checksum" "$current_checksum"
      any_changed=1
    fi

    i=$((i + 1))
  done

  if [[ "$any_changed" -eq 1 ]]; then
    printf '\nRun `hi ingest implement --force %s` to re-register changed sources.\n' "$topic_name"
    exit 1
  fi
}

# ── dispatcher ───────────────────────────────────────────────────────────────

main() {
  if [[ $# -eq 0 || "$1" == "--help" || "$1" == "-h" ]]; then
    usage; exit 0
  fi

  local subcommand="$1"; shift

  if [[ $# -eq 0 ]]; then
    hi_log_error "Missing topic name"
    usage; exit 2
  fi

  local topic_name="$1"; shift

  case "$subcommand" in
    plan)      cmd_plan      "$topic_name" "$@" ;;
    implement) cmd_implement "$topic_name" "$@" ;;
    verify)    cmd_verify    "$topic_name" "$@" ;;
    *) hi_log_error "Unknown subcommand: $subcommand"; usage; exit 2 ;;
  esac
}

main "$@"
