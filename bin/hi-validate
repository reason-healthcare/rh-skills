#!/usr/bin/env bash
# bin/hi-validate — Validate an artifact against its level schema

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=common.sh
source "$SCRIPT_DIR/common.sh"

usage() {
  cat <<EOF
Usage: hi validate <skill> <level> <artifact>

Arguments:
  skill      Skill name (kebab-case)
  level      Artifact level: l2 | l3
  artifact   Artifact name (without extension)

Options:
  -h, --help   Print usage

Exit codes:
  0  Valid (all required fields present; optional field warnings to stderr)
  1  Invalid (one or more required fields missing)
  2  Usage error

Examples:
  hi validate diabetes-screening l2 ada-criteria
  hi validate diabetes-screening l3 diabetes-computable
EOF
}

main() {
  if [[ $# -eq 0 || "$1" == "--help" || "$1" == "-h" ]]; then
    usage; exit 0
  fi

  if [[ $# -lt 3 ]]; then
    hi_log_error "validate requires: <skill> <level> <artifact>"
    usage; exit 2
  fi

  local skill_name="$1"
  local level="$2"
  local artifact_name="$3"

  # Validate level argument
  if [[ "$level" != "l2" && "$level" != "l3" ]]; then
    hi_log_error "Level must be l2 or l3 (got: $level)"
    exit 2
  fi

  local ext="yaml"
  local skill_dir
  skill_dir="$(hi_topic_dir "$skill_name")"
  local artifact_file="$skill_dir/$level/$artifact_name.$ext"
  local schema_file
  schema_file="$(hi_schemas_dir)/$level-schema.yaml"

  # Check skill and artifact exist
  if [[ ! -d "$skill_dir" ]]; then
    hi_log_error "Skill '$skill_name' not found"
    exit 2
  fi
  if [[ ! -f "$artifact_file" ]]; then
    hi_log_error "Artifact not found: $artifact_file"
    exit 2
  fi
  if [[ ! -f "$schema_file" ]]; then
    hi_log_error "Schema not found: $schema_file"
    exit 2
  fi

  # Check yq is available
  if ! command -v yq &>/dev/null; then
    hi_log_error "yq is required but not found. Install: brew install yq"
    exit 2
  fi

  local errors=0
  local warnings=0

  printf 'Validating %s/%s/%s...\n' "$skill_name" "$level" "$artifact_name"

  # Read required fields from schema
  local required_fields=()
  while IFS= read -r field; do
    [[ -n "$field" ]] && required_fields+=("$field")
  done < <(yq eval '.required_fields[]' "$schema_file" 2>/dev/null)

  for field in "${required_fields[@]}"; do
    # Handle nested fields like "metadata.id" using dot notation
    local val
    val=$(yq eval ".$field" "$artifact_file" 2>/dev/null)
    if [[ "$val" == "null" || -z "$val" ]]; then
      hi_log_error "  MISSING required field: $field"
      errors=$((errors + 1))
    fi
  done

  # Read optional fields from schema (warn only)
  local optional_fields=()
  while IFS= read -r field; do
    [[ -n "$field" ]] && optional_fields+=("$field")
  done < <(yq eval '.optional_fields[]? // ""' "$schema_file" 2>/dev/null | grep -v '^$')

  for field in "${optional_fields[@]:-}"; do
    [[ -z "$field" ]] && continue
    local val
    val=$(yq eval ".$field" "$artifact_file" 2>/dev/null)
    if [[ "$val" == "null" || -z "$val" ]]; then
      hi_log_warn "  optional field not set: $field" >&2
      warnings=$((warnings + 1))
    fi
  done

  if [[ $errors -gt 0 ]]; then
    printf 'INVALID — %d required field(s) missing\n' "$errors"
    exit 1
  else
    if [[ $warnings -gt 0 ]]; then
      printf 'VALID (with %d optional field warning(s))\n' "$warnings" >&2
    fi
    printf 'VALID — %s\n' "$artifact_file"
    exit 0
  fi
}

main "$@"
