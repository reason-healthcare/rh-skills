#!/usr/bin/env bash
# bin/hi-init — Scaffold a new skill

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=common.sh
source "$SCRIPT_DIR/common.sh"

usage() {
  cat <<EOF
Usage: hi init <topic-name> [options]

Arguments:
  topic-name   Name of the skill (kebab-case, e.g. diabetes-screening)

Options:
  --title      Human-readable title (default: derived from topic-name)
  --description  Brief description of the skill
  --author     Author name or team (default: git user or "unknown")
  -h, --help   Print usage

Exit codes:
  0  Success
  1  Skill already exists
  2  Usage error

Examples:
  hi init diabetes-screening
  hi init sepsis-detection --title "Sepsis Early Detection" --author "Clinical Informatics Team"
EOF
}

main() {
  if [[ $# -eq 0 || "$1" == "--help" || "$1" == "-h" ]]; then
    usage; exit 0
  fi

  local topic_name="$1"; shift

  # Validate topic name
  if ! hi_kebab_validate "$topic_name"; then
    hi_log_error "Topic name must be kebab-case (lowercase letters, digits, hyphens only): $topic_name"
    exit 2
  fi

  # Parse optional flags
  local title="" description="" author=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --title)       title="$2";       shift 2 ;;
      --description) description="$2"; shift 2 ;;
      --author)      author="$2";      shift 2 ;;
      -h|--help)     usage; exit 0 ;;
      *) hi_log_error "Unknown option: $1"; usage; exit 2 ;;
    esac
  done

  # Defaults
  if [[ -z "$title" ]]; then
    # Convert kebab-case to title case: diabetes-screening → Diabetes Screening
    title=$(echo "$topic_name" | sed 's/-/ /g' | awk '{for(i=1;i<=NF;i++) $i=toupper(substr($i,1,1)) substr($i,2); print}')
  fi
  if [[ -z "$author" ]]; then
    author=$(git config user.name 2>/dev/null || echo "unknown")
  fi

  local topics_root
  topics_root="$(hi_topics_root)"
  local topic_dir="$topics_root/$topic_name"

  # Check if topic already exists
  if [[ -d "$topic_dir" ]]; then
    hi_log_error "Topic '$topic_name' already exists at $topic_dir"
    exit 1
  fi

  # Create directory structure
  mkdir -p "$topic_dir/l2" "$topic_dir/l3" "$topic_dir/fixtures/results" "$topic_dir/plans"

  # Ensure root l1/ directory exists
  mkdir -p "$(hi_l1_root)"

  local timestamp
  timestamp="$(hi_timestamp)"
  local today
  today="$(hi_date)"

  # Initialize or update repo-level tracking.yaml
  local tracking
  tracking="$(hi_tracking_file)"
  if [[ ! -f "$tracking" ]]; then
    printf 'schema_version: "1.0"\nl1: []\ntopics: []\nevents: []\n' > "$tracking"
  fi

  # Append new topic entry (topics contain only l2 and l3 artifacts; l1 is at repo root)
  yq eval -i ".topics += [{\"name\": \"$topic_name\", \"title\": \"$title\", \"description\": \"${description:-A healthcare informatics topic}\", \"author\": \"$author\", \"created_at\": \"$timestamp\", \"artifacts\": {\"l2\": [], \"l3\": []}, \"events\": []}]" \
    "$tracking"

  # Record initial created event
  hi_tracking_append_event "$tracking" "$topic_name" "created" "Topic scaffolded with hi init"

  # Write TOPIC.md
  cat > "$topic_dir/TOPIC.md" <<MD
---
name: "$topic_name"
description: "${description:-A healthcare informatics topic}"
compatibility: "hi-skills-framework >= 0.1.0"
metadata:
  author: "$author"
  created: "$today"
  domain: ""
---

## Overview

${description:-Describe the clinical purpose and scope of this topic.}

## Artifact Levels

- **L1 (Discovery)**: Raw clinical knowledge — guidelines, notes, research extracts
- **L2 (Semi-structured)**: Structured YAML artifacts derived from L1 content
- **L3 (Computable)**: Computable YAML artifacts converged from L2, FHIR-compatible

## Instructions

<!-- Describe how an agent or human should reason about and use this topic. -->
MD

  hi_log_info "Initialized topic: $topic_name"
  printf '  Location: %s\n' "$topic_dir"
  printf '  Tracking: %s\n' "$tracking"
  printf '  Structure:\n'
  printf '    l1/        (shared raw sources — repo root)\n'
  printf '    %s/\n' "$topic_name"
  printf '      l2/        (semi-structured artifacts)\n'
  printf '      l3/        (computable artifacts)\n'
  printf '      plans/     (plan artifacts from framework skills)\n'
  printf '      fixtures/  (LLM test fixtures)\n'
  printf '      TOPIC.md   (topic description)\n'
  printf '  tracking.yaml  (repo-level workflow audit log)\n'
}

main "$@"
