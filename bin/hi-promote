#!/usr/bin/env bash
# bin/hi-promote — Promote artifact(s) to the next level
#
# Modes:
#   derive   L1 → L2  (one-to-many: one L1 produces N L2 artifacts via LLM)
#   combine  L2 → L3  (many-to-one: multiple L2 artifacts converge into one L3)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=common.sh
source "$SCRIPT_DIR/common.sh"
# shellcheck source=llm-lib.sh
source "$SCRIPT_DIR/llm-lib.sh"

usage() {
  cat <<EOF
Usage: hi promote <mode> <skill> [options]

Modes:
  derive   Promote L1 artifact(s) to L2 (requires --source, --name)
  combine  Promote L2 artifacts to L3   (requires --sources, --name)

Options (derive):
  --source <l1-name>    L1 artifact name to derive from (required)
  --name   <l2-name>    Output L2 artifact name (required)
  --count  <n>          Number of L2 artifacts to generate (default: 1)
  --dry-run             Print prompt only; do not invoke LLM

Options (combine):
  --sources <l2a,l2b>   Comma-separated L2 artifact names (required)
  --name    <l3-name>   Output L3 artifact name (required)
  --dry-run             Print prompt only; do not invoke LLM

Global:
  -h, --help            Print usage

Exit codes:
  0  Success
  1  Validation failure (required fields missing)
  2  Usage error

Examples:
  hi promote derive diabetes-screening --source ada-guidelines --name screening-criteria
  hi promote derive diabetes-screening --source ada-guidelines --name risk-factor --count 2
  hi promote combine diabetes-screening --sources screening-criteria,risk-factor --name diabetes-screening-computable
EOF
}

# ── Derive mode: L1 → L2 ─────────────────────────────────────────────────────

cmd_derive() {
  local skill_name="$1"; shift

  local source_name="" output_name="" count=1 dry_run=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --source)  source_name="$2"; shift 2 ;;
      --name)    output_name="$2"; shift 2 ;;
      --count)   count="$2";       shift 2 ;;
      --dry-run) dry_run=1;        shift   ;;
      -h|--help) usage; exit 0    ;;
      *) hi_log_error "Unknown option: $1"; usage; exit 2 ;;
    esac
  done

  if [[ -z "$source_name" || -z "$output_name" ]]; then
    hi_log_error "derive requires --source and --name"
    usage; exit 2
  fi

  hi_require_skill "$skill_name"
  local skill_dir
  skill_dir="$(hi_skill_dir "$skill_name")"
  local l1_file="$skill_dir/l1/$source_name.md"

  if [[ ! -f "$l1_file" ]]; then
    hi_log_error "L1 artifact not found: $l1_file"
    exit 2
  fi

  local l1_content
  l1_content=$(cat "$l1_file")

  local system_prompt
  system_prompt=$(cat <<'PROMPT'
You are a healthcare informatics specialist. Your task is to extract and structure clinical knowledge from raw discovery artifacts into a semi-structured YAML format.

The output MUST be valid YAML with these required fields:
  id, name, title, version, status, domain, description, derived_from

Rules:
- id: kebab-case identifier
- name: short machine name (no spaces)
- title: human-readable title
- version: "1.0.0"
- status: draft
- domain: clinical domain (e.g. diabetes, sepsis, hypertension)
- description: clear clinical description (2-4 sentences)
- derived_from: list containing the source L1 artifact name

Output ONLY the YAML block. No markdown fences, no explanation.
PROMPT
)

  local i=1
  while [[ $i -le $count ]]; do
    local artifact_name="$output_name"
    if [[ $count -gt 1 ]]; then
      artifact_name="${output_name}-${i}"
    fi

    local user_prompt="Source L1 artifact name: $source_name

Content:
$l1_content

Generate L2 artifact #$i of $count. Artifact name (id field): $artifact_name"

    if [[ $dry_run -eq 1 ]]; then
      printf -- '--- DRY RUN: derive prompt for %s ---\n' "$artifact_name"
      printf 'SYSTEM:\n%s\n\nUSER:\n%s\n' "$system_prompt" "$user_prompt"
      i=$((i + 1))
      continue
    fi

    printf 'Deriving L2 artifact: %s (from %s)...\n' "$artifact_name" "$source_name"

    local llm_output
    if ! llm_output=$(invoke_llm "$system_prompt" "$user_prompt"); then
      hi_log_error "LLM invocation failed for artifact $artifact_name"
      exit 2
    fi

    local l2_file="$skill_dir/l2/$artifact_name.yaml"
    printf '%s\n' "$llm_output" > "$l2_file"

    # Validate before recording
    if ! "$SCRIPT_DIR/hi-validate" "$skill_name" l2 "$artifact_name" >/dev/null 2>&1; then
      hi_log_warn "L2 artifact has validation warnings: $artifact_name"
    fi

    # Update tracking
    local timestamp
    timestamp="$(hi_timestamp)"
    local tracking="$skill_dir/tracking.yaml"
    yq eval -i ".artifacts.l2 += [{\"name\": \"$artifact_name\", \"created_at\": \"$timestamp\", \"derived_from\": [\"$source_name\"]}]" "$tracking"
    yq eval -i ".events += [{\"timestamp\": \"$timestamp\", \"type\": \"l2_derived\", \"description\": \"Derived $artifact_name from $source_name\"}]" "$tracking"

    hi_log_info "Created: $l2_file"
    i=$((i + 1))
  done
}

# ── Combine mode: L2 → L3 ────────────────────────────────────────────────────

cmd_combine() {
  local skill_name="$1"; shift

  local sources_csv="" output_name="" dry_run=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --sources) sources_csv="$2"; shift 2 ;;
      --name)    output_name="$2"; shift 2 ;;
      --dry-run) dry_run=1;        shift   ;;
      -h|--help) usage; exit 0    ;;
      *) hi_log_error "Unknown option: $1"; usage; exit 2 ;;
    esac
  done

  if [[ -z "$sources_csv" || -z "$output_name" ]]; then
    hi_log_error "combine requires --sources and --name"
    usage; exit 2
  fi

  hi_require_skill "$skill_name"
  local skill_dir
  skill_dir="$(hi_skill_dir "$skill_name")"

  # Parse comma-separated source list
  local combined_content="" source_names_yaml=""
  local IFS_ORIG="$IFS"
  IFS=','
  local sources_arr
  # shellcheck disable=SC2206  # intentional word split on IFS
  sources_arr=($sources_csv)
  IFS="$IFS_ORIG"

  for src in "${sources_arr[@]}"; do
    src="${src# }"; src="${src% }"   # trim spaces
    local l2_file="$skill_dir/l2/$src.yaml"
    if [[ ! -f "$l2_file" ]]; then
      hi_log_error "L2 artifact not found: $l2_file"
      exit 2
    fi
    combined_content="${combined_content}
--- L2: $src ---
$(cat "$l2_file")
"
    source_names_yaml="${source_names_yaml}  - $src
"
  done

  local system_prompt
  system_prompt=$(cat <<'PROMPT'
You are a healthcare informatics specialist. Your task is to converge multiple semi-structured L2 YAML artifacts into a single computable L3 YAML artifact using the hi-skills-framework schema.

The output MUST be valid YAML with this structure:

artifact_schema_version: "1.0"
metadata:
  id:           # kebab-case
  name:         # short machine name
  title:        # human-readable title
  version:      "1.0.0"
  status:       draft
  domain:       # clinical domain
  created_date: # YYYY-MM-DD
  description:  # clear description
converged_from:
  - <l2-artifact-name>

Then include ONE OR MORE of these optional sections appropriate to the clinical content:
  pathways, actions, libraries, measures, assessments, value_sets, code_systems

Each section should use FHIR-compatible field names. Include only sections with meaningful content.

Output ONLY the YAML block. No markdown fences, no explanation.
PROMPT
)

  local today
  today="$(hi_date)"
  local user_prompt="Output artifact name (id): $output_name
Today's date: $today
Source L2 artifacts:
$combined_content"

  if [[ $dry_run -eq 1 ]]; then
    printf -- '--- DRY RUN: combine prompt for %s ---\n' "$output_name"
    printf 'SYSTEM:\n%s\n\nUSER:\n%s\n' "$system_prompt" "$user_prompt"
    return 0
  fi

  printf 'Combining L2 artifacts into L3: %s...\n' "$output_name"
  printf 'Sources: %s\n' "$sources_csv"

  local llm_output
  if ! llm_output=$(invoke_llm "$system_prompt" "$user_prompt"); then
    hi_log_error "LLM invocation failed"
    exit 2
  fi

  local l3_file="$skill_dir/l3/$output_name.yaml"
  printf '%s\n' "$llm_output" > "$l3_file"

  # Validate
  if ! "$SCRIPT_DIR/hi-validate" "$skill_name" l3 "$output_name" >/dev/null 2>&1; then
    hi_log_warn "L3 artifact has validation warnings: $output_name"
  fi

  # Update tracking
  local timestamp
  timestamp="$(hi_timestamp)"
  local tracking="$skill_dir/tracking.yaml"

  # Build converged_from array for yq
  local converged_json="["
  local first=1
  for src in "${sources_arr[@]}"; do
    src="${src# }"; src="${src% }"
    if [[ $first -eq 1 ]]; then
      converged_json="${converged_json}\"$src\""
      first=0
    else
      converged_json="${converged_json},\"$src\""
    fi
  done
  converged_json="${converged_json}]"

  yq eval -i ".artifacts.l3 += [{\"name\": \"$output_name\", \"created_at\": \"$timestamp\", \"converged_from\": $converged_json}]" "$tracking"
  yq eval -i ".events += [{\"timestamp\": \"$timestamp\", \"type\": \"l3_converged\", \"description\": \"Converged $output_name from $sources_csv\"}]" "$tracking"

  hi_log_info "Created: $l3_file"
}

# ── Main ──────────────────────────────────────────────────────────────────────

main() {
  if [[ $# -eq 0 || "$1" == "--help" || "$1" == "-h" ]]; then
    usage; exit 0
  fi

  local mode="$1"; shift
  if [[ $# -eq 0 ]]; then
    hi_log_error "promote requires a skill name after mode"
    usage; exit 2
  fi
  local skill_name="$1"; shift

  case "$mode" in
    derive)  cmd_derive  "$skill_name" "$@" ;;
    combine) cmd_combine "$skill_name" "$@" ;;
    *)
      hi_log_error "Unknown mode '$mode' — must be: derive | combine"
      usage; exit 2
      ;;
  esac
}

main "$@"
