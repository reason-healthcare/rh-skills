#!/usr/bin/env bash
# bin/hi-test — Run LLM-based tests against skill fixtures

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=common.sh
source "$SCRIPT_DIR/common.sh"
# shellcheck source=llm-lib.sh
source "$SCRIPT_DIR/llm-lib.sh"

usage() {
  cat <<EOF
Usage: hi test <skill> [options]

Arguments:
  skill        Skill name to test

Options:
  --fixture <name>   Run a specific fixture (default: all)
  --mode <mode>      Comparison mode: exact | normalized | case_insensitive | contains | keywords
                     (default: normalized)
  -h, --help         Print usage

Exit codes:
  0  All tests passed
  1  One or more tests failed
  2  Usage error or infrastructure failure (curl timeout, missing fixture)

Output:
  Results are written to skills/<skill>/fixtures/results/<timestamp>-<runid>.json

Examples:
  hi test diabetes-screening
  hi test diabetes-screening --fixture ada-criteria-test --mode contains
EOF
}

# Generate a short random run ID (portable: use PID + timestamp fragment)
_run_id() {
  printf '%s-%s' "$$" "$(date -u +%H%M%S)"
}

main() {
  if [[ $# -eq 0 || "$1" == "--help" || "$1" == "-h" ]]; then
    usage; exit 0
  fi

  local skill_name="$1"; shift
  local fixture_filter="" compare_mode="normalized"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --fixture) fixture_filter="$2"; shift 2 ;;
      --mode)    compare_mode="$2";   shift 2 ;;
      -h|--help) usage; exit 0 ;;
      *) hi_log_error "Unknown option: $1"; usage; exit 2 ;;
    esac
  done

  hi_require_topic "$skill_name"
  local skill_dir
  skill_dir="$(hi_topic_dir "$skill_name")"
  local fixtures_dir="$skill_dir/fixtures"
  local results_dir="$fixtures_dir/results"
  mkdir -p "$results_dir"

  # Collect fixture files
  local fixtures=()
  if [[ -n "$fixture_filter" ]]; then
    local f="$fixtures_dir/${fixture_filter}.yaml"
    if [[ ! -f "$f" ]]; then
      hi_log_error "Fixture not found: $f"
      exit 2
    fi
    fixtures=("$f")
  else
    while IFS= read -r f; do
      [[ -n "$f" ]] && fixtures+=("$f")
    done < <(find "$fixtures_dir" -maxdepth 1 -name '*.yaml' -not -path '*/results/*' 2>/dev/null | sort)
  fi

  local fixture_count="${#fixtures[@]}"
  if [[ "$fixture_count" -eq 0 ]]; then
    hi_log_warn "No fixtures found in $fixtures_dir"
    exit 0
  fi

  local timestamp run_id result_file
  timestamp="$(hi_timestamp)"
  run_id="$(_run_id)"
  # Sanitize timestamp for filename: replace colons (not allowed on some FSes)
  local ts_safe
  ts_safe="$(printf '%s' "$timestamp" | tr -d ':')"
  result_file="$results_dir/${ts_safe}-${run_id}.json"

  local passed=0 failed=0 errored=0
  local results_json="[]"

  for fixture_file in "${fixtures[@]}"; do
    local fixture_name
    fixture_name="$(basename "$fixture_file" .yaml)"

    # Read fixture fields
    local system_prompt user_prompt expected_response
    system_prompt="$(yq eval '.system_prompt // ""' "$fixture_file")"
    user_prompt="$(yq eval '.user_prompt // ""'   "$fixture_file")"
    expected_response="$(yq eval '.expected_response // ""' "$fixture_file")"

    if [[ -z "$user_prompt" || -z "$expected_response" ]]; then
      hi_log_warn "Fixture '$fixture_name' missing user_prompt or expected_response — skipped"
      continue
    fi

    printf 'Running fixture: %s...' "$fixture_name"

    local actual_response outcome
    if ! actual_response=$(invoke_llm "$system_prompt" "$user_prompt"); then
      outcome="errored"
      errored=$((errored + 1))
      printf ' ERRORED\n'
    elif compare_llm_response "$actual_response" "$expected_response" "$compare_mode"; then
      outcome="passed"
      passed=$((passed + 1))
      printf ' PASSED\n'
    else
      outcome="failed"
      failed=$((failed + 1))
      printf ' FAILED\n'
    fi

    # Append result entry to JSON using jq
    local entry
    entry=$(jq -n \
      --arg name "$fixture_name" \
      --arg outcome "$outcome" \
      --arg mode "$compare_mode" \
      --arg expected "$expected_response" \
      --arg actual "${actual_response:-}" \
      '{name: $name, outcome: $outcome, mode: $mode, expected: $expected, actual: $actual}')
    results_json=$(printf '%s' "$results_json" | jq --argjson e "$entry" '. + [$e]')
  done

  # Write results JSON
  jq -n \
    --arg skill "$skill_name" \
    --arg timestamp "$timestamp" \
    --arg run_id "$run_id" \
    --arg provider "${LLM_PROVIDER:-ollama}" \
    --argjson passed "$passed" \
    --argjson failed "$failed" \
    --argjson errored "$errored" \
    --argjson results "$results_json" \
    '{skill: $skill, timestamp: $timestamp, run_id: $run_id, provider: $provider,
      summary: {passed: $passed, failed: $failed, errored: $errored},
      results: $results}' > "$result_file"

  printf '\nResults: %d passed, %d failed, %d errored\n' "$passed" "$failed" "$errored"
  printf 'Report: %s\n' "$result_file"

  if [[ $failed -gt 0 ]]; then
    exit 1
  fi
  exit 0
}

main "$@"
