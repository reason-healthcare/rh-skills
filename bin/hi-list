#!/usr/bin/env bash
# bin/hi-list — List all skills in the repository

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=common.sh
source "$SCRIPT_DIR/common.sh"

usage() {
  cat <<EOF
Usage: hi list [options]

Options:
  --json       Output as JSON array
  --stage <s>  Filter by lifecycle stage: initialized | l1-discovery |
               l2-semi-structured | l3-computable
  -h, --help   Print usage

Exit codes:
  0  Success
  2  Usage error

Examples:
  hi list
  hi list --json
  hi list --stage l3-computable
EOF
}

# Determine lifecycle stage from artifact counts
_skill_stage() {
  local l1="$1" l2="$2" l3="$3"
  if [[ "$l3" -gt 0 ]]; then
    echo "l3-computable"
  elif [[ "$l2" -gt 0 ]]; then
    echo "l2-semi-structured"
  elif [[ "$l1" -gt 0 ]]; then
    echo "l1-discovery"
  else
    echo "initialized"
  fi
}

main() {
  local json_output=0 stage_filter=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --json)    json_output=1;      shift ;;
      --stage)   stage_filter="$2";  shift 2 ;;
      -h|--help) usage; exit 0 ;;
      *) hi_log_error "Unknown option: $1"; usage; exit 2 ;;
    esac
  done

  local tracking
  tracking="$(hi_tracking_file)"

  if [[ ! -f "$tracking" ]]; then
    if [[ $json_output -eq 1 ]]; then
      echo "[]"
    else
      printf 'No tracking.yaml found\n'
    fi
    exit 0
  fi

  local skills_json="[]"
  local found=0

  local topic_count
  topic_count=$(yq eval '.topics | length' "$tracking" 2>/dev/null || echo 0)

  local i=0
  while [[ "$i" -lt "$topic_count" ]]; do
    local topic_name title l1_count l2_count l3_count stage
    topic_name=$(yq eval ".topics[$i].name" "$tracking" 2>/dev/null || echo "")
    title=$(yq eval ".topics[$i].title // \"\"" "$tracking" 2>/dev/null || echo "")
    l1_count=$(yq eval ".l1 | length" "$tracking" 2>/dev/null || echo 0)
    l2_count=$(yq eval ".topics[$i].artifacts.l2 | length" "$tracking" 2>/dev/null || echo 0)
    l3_count=$(yq eval ".topics[$i].artifacts.l3 | length" "$tracking" 2>/dev/null || echo 0)
    stage="$(_skill_stage "$l1_count" "$l2_count" "$l3_count")"

    # Apply stage filter
    if [[ -n "$stage_filter" && "$stage" != "$stage_filter" ]]; then
      i=$((i + 1))
      continue
    fi

    if [[ $json_output -eq 1 ]]; then
      local entry
      entry=$(jq -n \
        --arg name "$topic_name" \
        --arg title "$title" \
        --arg stage "$stage" \
        --argjson l1 "$l1_count" \
        --argjson l2 "$l2_count" \
        --argjson l3 "$l3_count" \
        '{name: $name, title: $title, stage: $stage, artifacts: {l1: $l1, l2: $l2, l3: $l3}}')
      skills_json=$(printf '%s' "$skills_json" | jq --argjson e "$entry" '. + [$e]')
    else
      printf '%-30s  %-20s  L1:%-3d L2:%-3d L3:%-3d\n' \
        "$topic_name" "$stage" "$l1_count" "$l2_count" "$l3_count"
    fi
    found=$((found + 1))
    i=$((i + 1))
  done

  if [[ $json_output -eq 1 ]]; then
    printf '%s\n' "$skills_json"
  elif [[ $found -eq 0 ]]; then
    printf 'No topics found%s\n' "${stage_filter:+ with stage: $stage_filter}"
  fi
}

main "$@"
