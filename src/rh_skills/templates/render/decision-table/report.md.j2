{% for a in actions %}{% set _ = action_map.update({a.id: a.label or a.id}) %}{% endfor %}
{% set cond_map = {} %}
{% for c in conditions %}{% set _ = cond_map.update({c.id: c.label or c.id}) %}{% endfor %}
