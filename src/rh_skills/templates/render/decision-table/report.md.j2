{% set sections = data.sections or {} %}
{% set matrix = decision_matrix or {} %}
{% set events = matrix.event_rows or [] %}
{% set conditions = matrix.condition_rows or [] %}
{% set actions = matrix.action_rows or [] %}
{% set rules = matrix.rule_rows or [] %}
# Decision Matrix - {{ data.title or data.name or '' }}

{% if data.clinical_question %}**Clinical Question**: {{ data.clinical_question }}
{% endif %}
{% if data.derived_from %}**Derived From**: {{ data.derived_from | join(', ') }}
{% endif %}

{% if sections.summary %}
## Summary

{{ sections.summary }}

{% endif %}
{% if events %}
## Event Key

| Key | Meaning |
|---|---|
{% for event in events -%}
| {{ event.key }} | {{ event.meaning }}{% if event.description and event.description != event.meaning %} - {{ event.description }}{% endif %} |
{% endfor %}

{% endif %}
{% if conditions %}
## Condition Key

| Key | Meaning | Allowed Values |
|---|---|---|
{% for condition in conditions -%}
| {{ condition.key }} | {{ condition.meaning }} | {{ condition["values"] | join(', ') }} |
{% endfor %}

{% endif %}
{% if actions %}
## Action Key

| Key | Meaning |
|---|---|
{% for action in actions -%}
| {{ action.key }} | {{ action.meaning }} |
{% endfor %}

{% endif %}
## Rules

|{% if events %} Event |{% endif %}{% for condition in conditions %} {{ condition.rule_header }} |{% endfor %} Actions |
|{% if events %}---|{% endif %}{% for condition in conditions %}---|{% endfor %}---|
{% for rule in rules -%}
|{% if events %} {{ rule.event }} |{% endif %}{% for value in rule.condition_values %} {{ value }} |{% endfor %} {{ rule.actions | join('; ') }} |
{% endfor %}

{% set traceability = sections.evidence_traceability or [] %}
{% if traceability %}
## Evidence Traceability

{% for entry in traceability -%}
- **{{ entry.claim_id or '?' }}**: {{ entry.statement or '' }}
{% for ev in (entry.evidence or []) %}  - Source: {{ ev.source or '?' }}, Locator: {{ ev.locator or '?' }}
{% endfor %}
{% endfor %}
{% endif %}
