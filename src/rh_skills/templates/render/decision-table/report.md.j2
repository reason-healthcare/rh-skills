{% set events = data.sections.events or [] %}
{% set conditions = data.sections.conditions or [] %}
{% set actions = data.sections.actions or [] %}
{% set rules = data.sections.rules or [] %}
{% set action_map = {} %}
{% for a in actions %}{% set _ = action_map.update({a.id: a.label or a.id}) %}{% endfor %}
{% set event_map = {} %}
{% for e in events %}{% set _ = event_map.update({e.id: e.label or e.id}) %}{% endfor %}
{% set cond_map = {} %}
{% for c in conditions %}{% set _ = cond_map.update({c.id: c.label or c.id}) %}{% endfor %}
# Decision Table — {{ data.title or data.name or '' }}

{% if data.clinical_question %}**Clinical Question**: {{ data.clinical_question }}
{% endif %}
{% if data.derived_from %}**Derived From**: {{ data.derived_from | join(', ') }}
{% endif %}

{% set sections = data.sections or {} %}
{% if sections.summary %}
## Summary

{{ sections.summary }}

{% endif %}
{% if events %}
## Events

{% for event in events -%}
- **{{ event.label or event.id or '?' }}**{% if event.description %}: {{ event.description }}{% endif %}
{% endfor %}

{% endif %}
| Rule |{% if events %} Event |{% endif %}{% for c in conditions %} {{ cond_map[c.id] }} |{% endfor %} Actions |
|---|{% if events %}---|{% endif %}{% for c in conditions %}---|{% endfor %}---|
{% for rule in rules -%}
| {{ rule.id or '?' }} |{% if events %} {{ event_map.get(rule.event, rule.event or '-') }} |{% endif %}{% for c in conditions %} {{ rule.when.get(c.id, '-') if rule.when is mapping else '-' }} |{% endfor %} {% if rule.then %}{% for aid in rule.then %}{{ action_map.get(aid, aid) }}{% if not loop.last %}, {% endif %}{% endfor %}{% endif %} |
{% endfor %}

