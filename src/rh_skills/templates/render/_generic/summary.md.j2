# {{ data.title or data.name or 'Untitled' }}

{% for field in ['id', 'title', 'domain', 'description', 'artifact_type', 'clinical_question'] -%}
{% if data[field] is defined and data[field] %}**{{ field }}**: {{ data[field] }}
{% endif %}
{%- endfor %}

{% macro render_val(v) %}
{%- if v is string or v is number %}{{ v }}
{%- elif v is mapping %}{% for mk, mv in v.items() %}{{ mk }}={{ mv }}{% if not loop.last %}, {% endif %}{% endfor %}
{%- elif v is iterable %}{% for sv in v %}{% if sv is mapping %}{% for mk, mv in sv.items() %}{{ mk }}={{ mv }}{% if not loop.last %} {% endif %}{% endfor %}{% else %}{{ sv }}{% endif %}{% if not loop.last %}; {% endif %}{% endfor %}
{%- endif %}
{%- endmacro %}

{% set sections = data.sections or {} %}
{% for key, val in sections.items() %}
## {{ key }}

{% if val is mapping %}
{% for k, v in val.items() %}- **{{ k }}**: {{ render_val(v) }}
{% endfor %}
{% elif val is iterable and val is not string %}
{% for item in val %}
{% if item is mapping %}
{% if item.get('label') %}{% set pk = 'label' %}{% elif item.get('name') %}{% set pk = 'name' %}{% elif item.get('title') %}{% set pk = 'title' %}{% elif item.get('statement') %}{% set pk = 'statement' %}{% elif item.get('issue') %}{% set pk = 'issue' %}{% else %}{% set pk = '' %}{% endif %}
- **{{ item.get(pk) or item.get('id') or '—' }}**{% if pk and item.get('id') and pk != 'id' %} `{{ item.id }}`{% endif %}

{% for k, v in item.items() if k != pk and k != 'id' or (k == 'id' and not pk) %}  - *{{ k }}*: {{ render_val(v) }}
{% endfor %}
{% else %}- {{ item }}
{% endif %}
{% endfor %}
{% else %}
{{ val }}
{% endif %}

{% endfor %}
